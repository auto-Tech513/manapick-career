{
  "name": "manapick-career",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "prebuild": "npm run content:check && npm run source:check && npm run similarity:check",
    "build": "next build",
    "start": "next dev --webpack",
    "lint": "eslint . --ignore-pattern out --ignore-pattern .next",
    "content:check": "node scripts/check-content.mjs",
    "source:check": "node scripts/audit-sources.mjs",
    "similarity:check": "node scripts/check-similarity.mjs",
    "links:check": "node scripts/audit-links.mjs --internal",
    "links:network": "node scripts/audit-links.mjs --network",
    "qa": "npm run lint && npm run content:check && npm run source:check && npm run similarity:check && npm run build && npm run links:check"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "type": "module",
  "overrides": {
    "postcss": "^8.5.10"
  }
}
